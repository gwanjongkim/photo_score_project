{
  "pipeline_name": "stage5_reference",
  "pipeline_version": "2026-04-02",
  "description": "Accepted practical A-cut ranking stack: baseline models, NIMA, MUSIQ, A-Lamp, RGNet, pairwise rerank, and diversity-aware reranking.",
  "bundle_args": {
    "aadb_model": "checkpoints/composition_aadb_gpu/final_model.keras",
    "koniq_model": "checkpoints/technical_koniq_gpu/final_model.keras",
    "flive_image_model": "checkpoints/technical_flive_image_gpu/final_model.keras",
    "flive_patch_model": "checkpoints/technical_flive_patch_gpu/final_model.keras",
    "nima_model": "checkpoints/nima_ava_gpu/final_model.keras",
    "alamp_model": "checkpoints/alamp_aadb_gpu/final_model.keras",
    "musiq_model": "checkpoints/musiq_aadb_gpu/final_model.keras",
    "rgnet_model": "checkpoints/rgnet_aadb_gpu/final_model.keras",
    "pairwise_model": "checkpoints/pairwise_aadb_gpu/final_model.keras",
    "pairwise_reference_csv": "data/processed/aadb/val.csv",
    "pairwise_target_col": "score",
    "pairwise_max_references": 16,
    "image_size": 224,
    "rgnet_image_size": 256,
    "alamp_global_size": 384,
    "alamp_patch_size": 224,
    "alamp_num_patches": 5,
    "alamp_patch_scale": 0.35,
    "musiq_patch_size": 32,
    "musiq_scale_sizes": "224,384,512",
    "musiq_patches_per_scale": 16
  },
  "selector_args": {
    "top_k": 5,
    "enable_pairwise_rerank": true,
    "rerank_pool_size": 10,
    "enable_diversity": true,
    "diversity_threshold": 0.82,
    "hard_duplicate_threshold": 0.88,
    "diversity_penalty_strength": 0.12,
    "score_recursive": false,
    "score_extensions": ".jpg,.jpeg,.png,.webp,.bmp"
  }
}
