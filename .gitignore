*.tar.gz
*.tgz
*.7z
*.rar
*.npy
*.npz

# Hugging Face / external model caches
**/hf_cache/
**/hub/models--*/


# --- Allow selected Flutter integration TFLite models ---
# General rule may ignore *.tflite, but these app-side A-cut models are allowed.
!exports/tflite/
!exports/tflite/*nima*.tflite
!exports/tflite/*rgnet*.tflite
!assets/
!assets/models/
!assets/models/*nima*.tflite
!assets/models/*rgnet*.tflite
