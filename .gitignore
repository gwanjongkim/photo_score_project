# Root-level model/checkpoint/weight stores only.
# Do not use "models/" without leading slash because it can ignore src/models/.
/models/
/weights/
/checkpoints/
/assets/models/

# Keep reports from outputs, but ignore large generated artifacts.
outputs/**
!outputs/**/
!outputs/**/*.md
!outputs/**/*.txt
!outputs/**/*.json
!outputs/**/*.csv

# Large model binaries / converted artifacts
*.tflite
*.h5
*.weights.h5
*.keras
*.ckpt
*.ckpt.*
*.pt
*.pth
*.onnx
*.pb
*.bin
*.safetensors
